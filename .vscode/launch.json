{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter iOS (simulador)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/flutter_app",
      "deviceId": "8DEFF3D4-A940-4561-B260-A5059FAD7B11",
      "args": [
        "--dart-define=API_BASE_URL=http://localhost:8080/index.php"
      ],
      "preLaunchTask": "📱 Abrir simulador iOS"
    },
    {
      "name": "Flutter web (API local)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/flutter_app",
      "deviceId": "chrome",
      "args": [
        "--dart-define=API_BASE_URL=http://localhost:8080/index.php"
      ],
      "preLaunchTask": "🐘 API PHP local"
    },
    {
      "name": "Flutter web (producción)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/flutter_app",
      "deviceId": "chrome"
    }
  ]
}
